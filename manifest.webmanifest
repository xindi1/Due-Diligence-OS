<!doctype html>
<html lang="en"><head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#f7faff" />
<title>Due Diligence OS</title>
<link rel="manifest" href="manifest.webmanifest" />
<link rel="apple-touch-icon" href="icons/icon-192.png" />
<link rel="stylesheet" href="styles.css" />
</head><body><div class="app-shell">
<header class="topbar"><div><p class="eyebrow">Opportunity Evaluation</p><h1>Due Diligence OS</h1></div><button id="themeBtn" class="icon-btn" aria-label="Toggle theme">◐</button></header>
<main>
<section id="dashboard" class="view active">
  <p class="eyebrow">Today · <span id="todayDate"></span></p>
  <section class="hero-card">
    <h2 id="greeting">Good morning, Rob.</h2>
    <p class="muted">Should you pursue this opportunity?</p>
    <button id="newOppBtn" class="primary-btn" type="button">New Opportunity</button>
    <div class="summary-list" id="oppCards"></div>
  </section>
  <section class="panel"><div class="panel-head"><h3>7-Day Research</h3><span id="trendLabel" class="mini-badge">Building signal</span></div><div id="weekBars" class="trend"></div></section>
  <section class="panel"><div class="panel-head"><h3>Today’s inputs</h3><span id="entryCount" class="muted small">0 entries</span></div><div id="todayEntries" class="entry-list"></div></section>
</section>

<section id="opportunity" class="view">
  <div class="domain-title"><span style="color:var(--blue)">Active Opportunity</span><h2 id="oppName">No opportunity</h2></div>
  <section class="hero-card">
    <div class="opp-stats"><div><strong id="oppTotal">0</strong><span>Total Inputs</span></div><div><strong id="oppRec">Explore</strong><span>Recommendation</span></div></div>
    <label class="metric-label">Recommendation</label>
    <select id="recSelect" onchange="setRecommendation(this.value)">
      <option>Kill</option><option>Monitor</option><option selected>Explore</option><option>Build</option><option>Accelerate</option>
    </select>
    <div class="actions-row"><button id="briefBtn" class="primary-btn" type="button">Generate Brief</button><button id="deleteOppBtn" class="secondary-btn" type="button">Delete</button></div>
    <div class="summary-list" id="trackCards"></div>
  </section>
</section>

<section id="capture" class="view">
  <div class="domain-title"><span style="color:var(--blue)">Capture</span><h2>Add input</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <form class="quick-form" data-track="capture">
    <textarea placeholder="Add a research question, market finding, customer quote, technology fit note, founder advantage, or commercialization path..." required></textarea>
    <input id="captureType" type="hidden" name="track" value="questions" />
    <div class="type-grid">
      <button class="type-option active" data-type="questions" type="button">?<span>Questions</span></button>
      <button class="type-option" data-type="market" type="button">◌<span>Market</span></button>
      <button class="type-option" data-type="competition" type="button">◈<span>Competition</span></button>
      <button class="type-option" data-type="customer" type="button">◉<span>Customer</span></button>
      <button class="type-option" data-type="technology" type="button">✦<span>Tech</span></button>
      <button class="type-option" data-type="advantage" type="button">◆<span>Advantage</span></button>
      <button class="type-option" data-type="commercialization" type="button">$<span>Commercial</span></button>
    </div>
    <button class="primary-btn" type="submit">Save Input</button>
  </form>
</section>


<section id="questions" class="view domain-view" data-track="questions">
  <div class="domain-title"><span>Unknowns</span><h2>Questions</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card questions-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="questionsMetric">0 entries</div><p class="muted small" id="questionsSub">Not logged</p></div>
    <div class="count-ring"><span id="questionsCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="questions">
    <textarea placeholder="What needs to be answered? Example: How many small HOAs exist in North Carolina?" required></textarea>
    <button class="primary-btn" type="submit">Save Questions</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="questions"></div>
  <h3>Questions Ledger</h3><div class="domain-entries"></div>
</section>

<section id="market" class="view domain-view" data-track="market">
  <div class="domain-title"><span>Size</span><h2>Market</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card market-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="marketMetric">0 entries</div><p class="muted small" id="marketSub">Not logged</p></div>
    <div class="count-ring"><span id="marketCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="market">
    <textarea placeholder="Is the market large enough to matter? Add counts, segments, geography, or growth signals." required></textarea>
    <button class="primary-btn" type="submit">Save Market</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="market"></div>
  <h3>Market Ledger</h3><div class="domain-entries"></div>
</section>

<section id="competition" class="view domain-view" data-track="competition">
  <div class="domain-title"><span>Alternatives</span><h2>Competition</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card competition-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="competitionMetric">0 entries</div><p class="muted small" id="competitionSub">Not logged</p></div>
    <div class="count-ring"><span id="competitionCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="competition">
    <textarea placeholder="Who already serves this need? Add competitors, pricing, features, complaints, or workarounds." required></textarea>
    <button class="primary-btn" type="submit">Save Competition</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="competition"></div>
  <h3>Competition Ledger</h3><div class="domain-entries"></div>
</section>

<section id="customer" class="view domain-view" data-track="customer">
  <div class="domain-title"><span>Voice</span><h2>Customer</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card customer-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="customerMetric">0 entries</div><p class="muted small" id="customerSub">Not logged</p></div>
    <div class="count-ring"><span id="customerCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="customer">
    <textarea placeholder="What do real users actually say? Add interviews, quotes, pain points, or observations." required></textarea>
    <button class="primary-btn" type="submit">Save Customer</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="customer"></div>
  <h3>Customer Ledger</h3><div class="domain-entries"></div>
</section>

<section id="technology" class="view domain-view" data-track="technology">
  <div class="domain-title"><span>Fit</span><h2>Technology Fit</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card technology-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="technologyMetric">0 entries</div><p class="muted small" id="technologySub">Not logged</p></div>
    <div class="count-ring"><span id="technologyCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="technology">
    <textarea placeholder="Is technology actually useful here? Add repetitive, rules-based, communication-heavy, or judgment-heavy tasks." required></textarea>
    <button class="primary-btn" type="submit">Save Technology Fit</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="technology"></div>
  <h3>Technology Fit Ledger</h3><div class="domain-entries"></div>
</section>

<section id="advantage" class="view domain-view" data-track="advantage">
  <div class="domain-title"><span>Proximity</span><h2>Founder Advantage</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card advantage-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="advantageMetric">0 entries</div><p class="muted small" id="advantageSub">Not logged</p></div>
    <div class="count-ring"><span id="advantageCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="advantage">
    <textarea placeholder="Why are you uniquely positioned? Add access, experience, relationships, documents, or credibility." required></textarea>
    <button class="primary-btn" type="submit">Save Founder Advantage</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="advantage"></div>
  <h3>Founder Advantage Ledger</h3><div class="domain-entries"></div>
</section>

<section id="commercialization" class="view domain-view" data-track="commercialization">
  <div class="domain-title"><span>Money</span><h2>Commercialization</h2></div>
  <div class="date-pill"><button type="button">‹</button><span>Today</span><button type="button">›</button></div>
  <section class="card metric-card commercialization-accent">
    <div><div class="metric-label">Current opportunity</div><div class="metric-value" id="commercializationMetric">0 entries</div><p class="muted small" id="commercializationSub">Not logged</p></div>
    <div class="count-ring"><span id="commercializationCount">0</span><small>inputs</small></div>
  </section>
  <form class="quick-form" data-track="commercialization">
    <textarea placeholder="How does this become money? Add SaaS, services, licensing, enterprise, partnership, or pricing paths." required></textarea>
    <button class="primary-btn" type="submit">Save Commercialization</button>
  </form>
  <h3>Quick Add</h3><div class="chips" data-target="commercialization"></div>
  <h3>Commercialization Ledger</h3><div class="domain-entries"></div>
</section>

<section id="settings" class="view">
  <div class="domain-title"><span style="color:var(--blue)">Control</span><h2>More</h2></div>
  <section class="panel"><h3>Data</h3><div class="settings-actions"><button id="exportBtn">Export JSON</button><label class="file-btn">Import JSON<input id="importFile" type="file" accept="application/json" hidden /></label><button id="clearBtn" class="danger">Clear All</button></div><p class="muted small">All opportunities are stored locally on this device.</p></section>
  <section class="panel"><h3>Product frame</h3><p class="muted">Due Diligence OS evaluates opportunities through questions, market, competition, customer, technology fit, founder advantage, and commercialization.</p></section>
</section>
</main>
<nav class="bottom-nav" aria-label="Primary navigation">
  <button class="nav-btn active" data-view="dashboard">⌂<span>Home</span></button>
  <button class="nav-btn" data-view="opportunity">⌁<span>Opp</span></button>
  <button class="nav-btn" data-view="capture">＋<span>Capture</span></button>
  <button class="nav-btn" data-view="questions">?<span>Questions</span></button>
  <button class="nav-btn" data-view="customer">◉<span>Customer</span></button>
  <button class="nav-btn" data-view="settings">☰<span>More</span></button>
</nav>
</div><script src="app.js"></script></body></html>